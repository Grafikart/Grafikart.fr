{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "todowrite": "allow",
        "laravel-boost*": "allow",
        "vendor/bin/pint*": "allow",
        "php -l *": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "grep": "allow",
        "list": "allow",
        "glob": "allow"
    },
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": ["php", "artisan", "boost:mcp"]
        }
    }
}
