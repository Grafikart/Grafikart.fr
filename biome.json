{
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["resources/**", "!resources/views/mail/*"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": false
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noChildrenProp": "off",
        "useExhaustiveDependencies": "warn",
        "noUnknownPseudoElement": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noDocumentCookie": "off",
        "useIterableCallbackReturn": "off"
      },
      "nursery": {
        "useSortedClasses": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [{ "source": ":EXTERNAL:" }, { "source": ":INTERNAL:" }]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.yml"],
      "formatter": {
        "indentWidth": 2
      }
    }
  ]
}
