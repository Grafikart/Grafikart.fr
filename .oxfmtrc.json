{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 2,
    "printWidth": 80,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "semi": false,
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "ignorePatterns": ["resources/views/mail/*", "*.yml", "*.md"],
    "overrides": [
        {
            "files": ["*.json"],
            "options": { "tabWidth": 4 }
        }
    ]
}
