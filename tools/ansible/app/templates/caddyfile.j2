{{ domain }} {
	encode zstd br gzip
	handle /downloads/* {
		forward_auth {{ domain }} {
			uri /auth/check/premium
		}
		uri strip_prefix /downloads
		root * downloads/
		file_server
	}

	# Static assets — served directly, no PHP involved
	@assets {
		path /build/* /favicons/* /images/* /schools/* /uploads/* /favicon.ico /favicon.svg /robots.txt /error.html /opensearch.xml /manifest.webmanifest /print.css /notification.mp3
	}

	handle @assets {
		root * {{ root_path }}/public/

		@versioned path_regexp \.(css|js)$
		header @versioned Cache-Control "public, max-age=31536000, immutable"

		@images path_regexp \.(jpe?g|png|gif|webp|avif|svg|ico|mp3)$
		header @images Cache-Control "public, max-age=2592000"

		@fonts path_regexp \.(woff2?|ttf|eot)$
		header @fonts Cache-Control "public, max-age=31536000, immutable"

		file_server
	}

	# Everything else → Laravel
	handle {
		root * {{ root_path }}/public/
		php_server
	}
	mercure {
		publisher_jwt {{ mercure_publisher_key }}
		subscriber_jwt {{ mercure_subscriber_key }}
	}
}
